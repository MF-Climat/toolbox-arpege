FILE_DBASE6_geopot="${FILE_PATH_DBASE6}/arp_reanalysis.surfgeopotential.01.bin:rel_GL"
# Monthly files: /!\ replace the month number by MM in your original filename !
FILE_DBASE2_veglai="${FILE_PATH_DBASE2}/giardbazile2000.vegetation.01.bin.mMM:veg_GL ${FILE_PATH_DBASE2}/giardbazile2000.lai.01.bin.mMM:lai_GL"
