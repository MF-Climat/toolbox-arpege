#=== Binaries
pack=/scratch/climat/packs/CY49T1_clim1.03.IMPIIFC2302DP.y/bin
EXEPGD=$pack/PGD
EXEPREP=$pack/PREP
EXEARP=$pack/MASTERODB

#=== Geometry
GRID=NFR2.5
GRIDl=NFR2.5l60

#=== Output directory: define SAVEDIR if wanted. Default : $workdir. Prefix, completed by each different job, e.g. : $SAVEDIR/pgd-prep/$expname
SAVEDIR=$workdir/arome/tests/${GRID}

#=== Namelists
NAMSFX=/home/gmgec/mrgo/gevaudanm/arome/tests/${GRID}/namelist/sfx/nam.sfx.ARCM.${GRID}.cy49t1_clim1.03.rl.teb
NAMSFXpgd=$NAMSFX ; NAMSFXc923=$NAMSFX ; NAMSFXc927=$NAMSFX
NAMLIN=/home/gmgec/mrgo/gevaudanm/arome/tests/${GRID}/namelist/atm/nam923.${GRID}.cy49t1.lin
NAMQUAD=/home/gmgec/mrgo/gevaudanm/arome/tests/${GRID}/namelist/atm/nam923.${GRID}.cy49t1.quad

#=== Restarts
resdir=/scratch/climat/CEDRE/restart/sfx/tl127r/v7
FA_PGDFILE=$resdir/PGD.AGCM.tl127r.cy49t1_clim1.03.fa
FA_INITFILE=$resdir/rst.sfx.AGCM.tl127r.cy49t1_clim1.03.19790101.fa

#=== PGD Input Data
ECODIR=/scratch/climat/APPS/regional_tools/preprocessing/pgd_data/cy49t1_clim-op1.01
ECOFILEScst="${ECODIR}/ecoclimapI_covers_param.08.bin:ecoclimapI_covers_param.bin ${ECODIR}/ecoclimapII_eu_covers_param.08.bin:ecoclimapII_eu_covers_param.bin ${ECODIR}/ecoclimapII_af_covers_param.08.bin:ecoclimapII_af_covers_param.bin"
ECOFILES="${ECODIR}/orography.gmted2010_07s5.01.dir:topo.dir ${ECODIR}/orography.gmted2010_07s5.01.hdr:topo.hdr"
ECOFILES+=" ${ECODIR}/ecoclimap_i.v1_8.02.dir:ecoclimap.dir ${ECODIR}/ecoclimap_i.v1_8.02.hdr:ecoclimap.hdr"
ECOFILES+=" ${ECODIR}/lake_depth_eco_i_v1.7.dir:lake_depth.dir ${ECODIR}/lake_depth_eco_i_v1.7.hdr:lake_depth.hdr"
ECOFILES+=" ${ECODIR}/hwsd.clay_v2.02.dir:clay.dir ${ECODIR}/hwsd.clay_v2.02.hdr:clay.hdr"
ECOFILES+=" ${ECODIR}/hwsd.sand_v2.02.dir:sand.dir ${ECODIR}/hwsd.sand_v2.02.hdr:sand.hdr"

#=== Paths for clim data
FILE_PATH_DBASE=/scratch/climat/APPS/regional_tools/preprocessing/923_data/cy49t1_clim-op1.01
