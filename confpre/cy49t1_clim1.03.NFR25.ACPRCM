FILE_PATH_DBASE8=${FILE_PATH_DBASE}/ugamp.ozone.01.ascii
FILE_PATH_DBASE9=${FILE_PATH_DBASE}/tegen.aerosols.01.ascii

#=== Files for each case different from ARPEGE/ALADIN
