FILE_DBASE8="${FILE_PATH_DBASE8}/ugamp.ozone.01.ascii.mMM:abc_coef"
FILE_DBASE9="${FILE_PATH_DBASE9}/tegen.aerosols.01.ascii.mMM:aero_GL"

#=== Handling of spectral orography for AROME
LAROME=true
EPY_ORO=$FILE_PATH_DBASE/scripts/epy_oro.py

